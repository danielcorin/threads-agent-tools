{
  "database_path": "threads-agent-bridge.db",
  "scopes": [
    {
      "id": "personal-codex",
      "threads": {
        "base_url": "https://threads-api.filae.site",
        "token_env": "THREADS_API_TOKEN"
      },
      "match": {
        "channel_ids": ["CHANNEL_ID"],
        "thread_ids": []
      },
      "runner": {
        "type": "codex",
        "command": "codex",
        "args": ["exec", "--json"],
        "working_dir": "/Users/dancorin/dev"
      },
      "safety": {
        "mode": "read-only",
        "allowed_tools": []
      }
    }
  ]
}
